HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
# Whisper model: tiny.en | base.en | small.en | medium.en (default)
WHISPER_MODEL=medium.en

# v0.4: Database
DB_PATH=data/pronuncy.db

# v0.4: Agent API (OpenAI-compatible)
AGENT_PROVIDER=openai
AGENT_API_KEY=your-api-key-here
AGENT_MODEL=gpt-4o
AGENT_BASE_URL=https://api.openai.com/v1
